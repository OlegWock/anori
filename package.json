{
    "name": "Anori",
    "description": "Customizable new tab: compose your own page from widgets",
    "version": "1.27.2",
    "type": "module",
    "repository": "git@github.com:OlegWock/anori.git",
    "author": "OlegWock",
    "license": "AGPL-3.0",
    "packageManager": "pnpm@10.28.1",
    "scripts": {
        "react-devtools": "react-devtools",
        "dev": "rspack build --mode development",
        "production": "rspack build --mode production",
        "production:unminified": "rspack build --mode production --env unminified",
        "dev:rsdoctor": "cross-env RSDOCTOR='true' rspack build --mode development",
        "production:rsdoctor": "cross-env RSDOCTOR='true' rspack build --mode production",
        "production:all-permissions": "rspack build --mode production --env targetBrowser=chrome-all-permissions",
        "watch": "rspack build --mode development --watch",
        "dev:ff": "rspack build --mode development --env targetBrowser=firefox",
        "production:ff": "rspack build --mode production --env targetBrowser=firefox",
        "watch:ff": "rspack build --mode development --watch --env targetBrowser=firefox",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepare": "husky && panda codegen",
        "fmt": "biome format --write .",
        "lint": "biome lint --write .",
        "biome:check": "biome check --write .",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "translations:status": "ts-node translations-manager.ts status",
        "translations:translate": "ts-node translations-manager.ts translate",
        "translations:clean": "ts-node translations-manager.ts remove-excessive",
        "translations:locales": "ts-node translations-manager.ts generate-locales"
    },
    "lint-staged": {
        "*": [
            "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write"
        ]
    },
    "dependencies": {
        "@anori-app/api-client": "^2.0.24",
        "@anori-app/api-types": "^2.0.24",
        "@base-ui/react": "^1.5.0",
        "@iconify/json": "^2.2.485",
        "@iconify/react": "^6.0.2",
        "@iconify/types": "^2.0.0",
        "@radix-ui/react-checkbox": "^1.3.4",
        "@radix-ui/react-direction": "^1.1.2",
        "@radix-ui/react-menubar": "^1.1.17",
        "@radix-ui/react-select": "^2.3.0",
        "@radix-ui/react-slider": "^1.4.0",
        "@radix-ui/react-tabs": "^1.1.14",
        "@rsdoctor/rspack-plugin": "^1.5.13",
        "@rspack/cli": "^1.7.11",
        "@rspack/core": "^1.7.11",
        "@svgr/core": "^8.1.0",
        "@svgr/plugin-jsx": "^8.1.0",
        "@tanstack/query-async-storage-persister": "^5.101.0",
        "@tanstack/react-query": "^5.101.0",
        "@tanstack/react-query-persist-client": "^5.101.0",
        "@tanstack/react-virtual": "^3.14.2",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/webextension-polyfill": "^0.12.5",
        "apca-w3": "^0.1.9",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "culori": "^4.0.2",
        "file-loader": "^6.2.0",
        "filemanager-webpack-plugin": "^10.0.1",
        "generate-file-webpack-plugin": "^1.0.1",
        "husky": "^9.1.7",
        "i18next": "^26.3.1",
        "jotai": "^2.20.1",
        "jszip": "^3.10.1",
        "lodash": "^4.18.1",
        "mathjs": "^15.2.0",
        "moment": "^2.30.1",
        "moment-locales-webpack-plugin": "^1.2.0",
        "moment-timezone": "^0.6.2",
        "moment-timezone-data-webpack-plugin": "^1.5.1",
        "motion": "^12.40.0",
        "react": "^19.2.7",
        "react-devtools": "^7.0.1",
        "react-devtools-core": "^7.0.1",
        "react-dom": "^19.2.7",
        "react-hotkeys-hook": "^5.3.2",
        "react-i18next": "^17.0.8",
        "react-markdown": "^10.1.0",
        "react-merge-refs": "^3.0.2",
        "react-use-motion-measure": "^4.0.0",
        "react-window": "^2.2.7",
        "remark-breaks": "^4.0.0",
        "remark-gfm": "^4.0.1",
        "rss-parser": "^3.13.0",
        "stream-browserify": "^3.0.0",
        "string-replace-loader": "^3.3.0",
        "style-loader": "^4.0.0",
        "timers-browserify": "^2.0.12",
        "to-string-loader": "^1.2.0",
        "ts-checker-rspack-plugin": "^1.4.0",
        "ts-loader": "^9.6.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "unplugin-icons": "^23.0.1",
        "url": "^0.11.4",
        "walk-sync": "^4.0.2",
        "webext-detect": "^5.3.2",
        "webextension-polyfill": "^0.12.0",
        "webpack": "^5.107.2",
        "webpack-target-webextension": "^2.1.3",
        "zod": "^4.4.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron"
        ]
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@pandacss/dev": "^1.11.3",
        "@pandacss/preset-base": "1.11.3",
        "@testing-library/react": "^16.3.2",
        "@types/culori": "^4.0.1",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.7",
        "postcss": "^8.5.15",
        "postcss-loader": "^8.2.1",
        "vitest": "^4.1.8"
    }
}
